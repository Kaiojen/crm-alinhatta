{
  "version": 2,
  "buildCommand": "",
  "framework": null,
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/followup-alerts",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/daily-report",
      "schedule": "0 21 * * *"
    }
  ]
}

