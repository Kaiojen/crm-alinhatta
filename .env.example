# Configuração do Supabase
# Copie este arquivo para .env e preencha com suas credenciais

# URL do projeto Supabase
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave Anon/Public do Supabase (seguro para usar no frontend)
SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Vercel KV (opcional - para cache/fallback)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ============================================================
# Alertas de follow-up + relatório diário no WhatsApp (Vercel Cron)
# Definir estas variáveis no painel da Vercel (Settings > Environment Variables).
# Veja o passo a passo completo em GUIA-WHATSAPP.md
# ============================================================

# Chave SERVICE ROLE do Supabase (somente servidor — NUNCA expor no frontend)
# Usada pelos crons para ler a tabela leads ignorando o RLS.
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Cloud API (oficial da Meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Opcionais (têm valor padrão):
WHATSAPP_API_VERSION=v21.0
WHATSAPP_TEMPLATE_LANG=pt_BR
WHATSAPP_TEMPLATE_FOLLOWUP=followup_alerta
WHATSAPP_TEMPLATE_REPORT=relatorio_diario

# Mapa SDR -> telefone (chaves IGUAIS ao campo "owner" do lead, com DDI 55)
SDR_PHONES={"Gabriel":"5531999999999","Dacunha":"5531888888888"}

# Telefones que recebem o resumo GERAL (opcional, separados por vírgula)
ADMIN_PHONES=

# Segredo para proteger os endpoints de cron (recomendado)
CRON_SECRET=
